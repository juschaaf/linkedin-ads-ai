# LinkedIn App credentials (create app at https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Comma-separated list of LinkedIn Ad Account IDs (numeric, without "urn:li:sponsoredAccount:" prefix)
# Find these in LinkedIn Campaign Manager URL: campaignmanager.linkedin.com/accounts/XXXXXXX
LINKEDIN_ACCOUNT_IDS=123456789,987654321

# Tokens are written here automatically after running: python main.py --auth
# LINKEDIN_TOKEN_123456789={"access_token": "...", "refresh_token": "...", "expires_at": ...}
